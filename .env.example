# dbt Cloud Configuration
DBT_HOST=cloud.getdbt.com
DBT_PROD_ENV_ID=your-production-environment-id
DBT_DEV_ENV_ID=your-development-environment-id
DBT_USER_ID=your-user-id
DBT_TOKEN=your-service-token

# Local dbt Configuration
DBT_PROJECT_DIR=/path/to/your/dbt/project
DBT_PATH=/path/to/your/dbt/executable

# Local FastMCP server bind settings
# Defaults: FASTMCP_HOST=127.0.0.1, FASTMCP_PORT=8000
FASTMCP_HOST=
FASTMCP_PORT=

# Multi-tenant Configuration
MULTICELL_ACCOUNT_PREFIX=your-account-prefix

# Tool Configuration
DISABLE_TOOLS=your-disabled-tools
DBT_MCP_ENABLE_TOOLS=your-enabled-tools
DBT_MCP_ENABLE_SEMANTIC_LAYER=
DBT_MCP_ENABLE_ADMIN_API=
DBT_MCP_ENABLE_DBT_CLI=
DBT_MCP_ENABLE_DBT_CODEGEN=
DBT_MCP_ENABLE_DISCOVERY=
DBT_MCP_ENABLE_LSP=
DBT_MCP_ENABLE_SQL=

# OIDC auth gateway for inbound remote MCP requests
# (separate from DBT_TOKEN / dbt platform OAuth)
# Required: enabled, issuer, resource server URL, client id
DBT_MCP_OIDC_ENABLED=
DBT_MCP_OIDC_ISSUER_URL=
DBT_MCP_OIDC_RESOURCE_SERVER_URL=
# Optional: set for introspection-based validation flows.
# Leave blank to use JWT/JWKS verification against issuer metadata.
DBT_MCP_OIDC_INTROSPECTION_ENDPOINT=
DBT_MCP_OIDC_CLIENT_ID=
# Required only when DBT_MCP_OIDC_INTROSPECTION_ENDPOINT is set.
DBT_MCP_OIDC_CLIENT_SECRET=
# Comma-separated values are supported, e.g. "openid,profile,email"
DBT_MCP_OIDC_REQUIRED_SCOPES=

# Optional native MCP OAuth broker mode (for IdPs without dynamic client registration).
# When true, dbt-mcp exposes /register, /authorize and /token as a local broker.
DBT_MCP_OIDC_NATIVE_AUTH_ENABLED=
# Optional explicit broker issuer URL. Defaults to resource server origin.
DBT_MCP_OIDC_AUTH_SERVER_ISSUER_URL=
# Optional token/JWT issuer override for inbound bearer token validation.
DBT_MCP_OIDC_TOKEN_ISSUER_URL=
# Optional callback URL for upstream IdP redirect. Defaults to <resource-origin>/callback.
DBT_MCP_OIDC_CALLBACK_URL=
